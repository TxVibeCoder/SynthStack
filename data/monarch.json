{
  "id": "monarch",
  "displayName": "Monarch",
  "internalSources": ["MON_NOISE", "MON_EG", "MON_KB_GATE", "MON_ZERO", "MON_PLUS5"],
  "controls": [
    { "id": "MON_FREQUENCY", "panelLabel": "FREQUENCY", "type": "knob", "min": -1, "max": 1, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Monarch p.11", "notes": "±1 octave around center (C4 ref)" },
    { "id": "MON_VCO_WAVE", "panelLabel": "VCO WAVE", "type": "switch", "positions": ["SAW", "PULSE"], "default": "SAW", "manualRef": "Monarch p.11", "notes": "selected wave feeds MIX CCW side" },
    { "id": "MON_PULSE_WIDTH", "panelLabel": "PULSE WIDTH", "type": "knob", "min": 0.02, "max": 0.98, "default": 0.5, "taper": "lin", "unit": "%", "manualRef": "Monarch p.11", "notes": "square at center; 0/100% silences (authentic)" },
    { "id": "MON_VCO_MOD_SOURCE", "panelLabel": "VCO MOD SOURCE", "type": "switch", "positions": ["LFO", "EG"], "default": "LFO", "manualRef": "Monarch p.12", "notes": "EG position is replaced by VCO MOD jack when patched (pattern-2 normal)" },
    { "id": "MON_VCO_MOD_AMOUNT", "panelLabel": "VCO MOD AMOUNT", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Monarch p.12" },
    { "id": "MON_VCO_MOD_DEST", "panelLabel": "VCO MOD DEST", "type": "switch", "positions": ["PW", "FREQUENCY"], "default": "FREQUENCY", "manualRef": "Monarch p.12" },
    { "id": "MON_LFO_RATE", "panelLabel": "LFO RATE", "type": "knob", "min": 0.1, "max": 350, "default": 5, "taper": "exp", "unit": "Hz", "manualRef": "Monarch p.13", "notes": "0.1–350 Hz; up to 600 Hz with CV" },
    { "id": "MON_LFO_WAVE", "panelLabel": "LFO WAVE", "type": "switch", "positions": ["TRI", "SQ"], "default": "TRI", "manualRef": "Monarch p.13" },
    { "id": "MON_MIX", "panelLabel": "MIX", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Monarch p.13", "notes": "equal-power crossfade VCO (CCW) vs noise/ext (CW)" },
    { "id": "MON_VCF_CUTOFF", "panelLabel": "CUTOFF", "type": "knob", "min": 20, "max": 20000, "default": 800, "taper": "exp", "unit": "Hz", "manualRef": "Monarch p.14" },
    { "id": "MON_VCF_RESONANCE", "panelLabel": "RESONANCE", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Monarch p.14", "notes": "self-oscillation above ~3 o'clock in LP mode" },
    { "id": "MON_VCF_MODE", "panelLabel": "VCF MODE", "type": "switch", "positions": ["LP", "HP"], "default": "LP", "manualRef": "Monarch pp.14-15", "notes": "HP is non-resonant; raising resonance reintroduces bottom end" },
    { "id": "MON_VCF_MOD_SOURCE", "panelLabel": "VCF MOD SOURCE", "type": "switch", "positions": ["LFO", "EG"], "default": "EG", "manualRef": "Monarch p.15" },
    { "id": "MON_VCF_MOD_AMOUNT", "panelLabel": "VCF MOD AMOUNT", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Monarch p.15" },
    { "id": "MON_VCF_MOD_POLARITY", "panelLabel": "VCF MOD POLARITY", "type": "switch", "positions": ["MINUS", "PLUS"], "default": "PLUS", "manualRef": "Monarch p.15" },
    { "id": "MON_ATTACK", "panelLabel": "ATTACK", "type": "knob", "min": 0.001, "max": 10, "default": 0.01, "taper": "exp", "unit": "s", "manualRef": "Monarch p.16", "notes": "1 ms–10 s assumed" },
    { "id": "MON_DECAY", "panelLabel": "DECAY", "type": "knob", "min": 0.001, "max": 10, "default": 0.3, "taper": "exp", "unit": "s", "manualRef": "Monarch p.16" },
    { "id": "MON_SUSTAIN", "panelLabel": "SUSTAIN", "type": "switch", "positions": ["OFF", "ON"], "default": "ON", "manualRef": "Monarch p.16", "notes": "semantics per work order D2" },
    { "id": "MON_VCA_MODE", "panelLabel": "VCA MODE", "type": "switch", "positions": ["EG", "ON"], "default": "EG", "manualRef": "Monarch p.16" },
    { "id": "MON_VOLUME", "panelLabel": "VOLUME", "type": "knob", "min": 0, "max": 1, "default": 0.7, "taper": "lin", "manualRef": "Monarch p.16" },
    { "id": "MON_GLIDE", "panelLabel": "GLIDE", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "exp", "unit": "s", "manualRef": "Monarch p.17", "notes": "portamento time; per-step glide enable lives in the sequencer" },
    { "id": "MON_VC_MIX", "panelLabel": "VC MIX", "type": "knob", "min": 0, "max": 1, "default": 0.5, "taper": "lin", "manualRef": "Monarch p.17", "notes": "crossfades MIX 1 (CCW) vs MIX 2 (CW)" },
    { "id": "MON_TEMPO", "panelLabel": "TEMPO", "type": "knob", "min": 20, "max": 300, "default": 120, "taper": "exp", "unit": "BPM", "manualRef": "Monarch p.18" },
    { "id": "MON_SWING", "panelLabel": "SWING", "type": "knob", "min": 0, "max": 100, "default": 50, "taper": "lin", "unit": "%", "manualRef": "Monarch pp.19-20", "notes": "hardware accesses swing via SHIFT; emulator gives it a knob (work order §9.3)" },
    { "id": "MON_RUN_STOP", "panelLabel": "RUN/STOP", "type": "button", "manualRef": "Monarch p.18" },
    { "id": "MON_RESET", "panelLabel": "RESET", "type": "button", "manualRef": "Monarch p.18" },
    { "id": "MON_HOLD", "panelLabel": "HOLD", "type": "button", "manualRef": "Monarch p.18" }
  ],
  "jacks": [
    { "id": "MON_EXT_AUDIO_IN", "panelLabel": "EXT AUDIO", "direction": "in", "signal": "audio", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:MON_NOISE", "feedsInternal": "Replaces noise at MIX knob CW side; MIX becomes VCO-vs-ext balance", "manualRef": "Monarch p.47" },
    { "id": "MON_MIX_CV_IN", "panelLabel": "MIX CV", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with MIX knob; ±5 vv = full crossfade at center knob", "manualRef": "Monarch p.47" },
    { "id": "MON_VCA_CV_IN", "panelLabel": "VCA CV", "direction": "in", "signal": "cv", "rangeVv": [0, 8], "normalledTo": null, "feedsInternal": "Sums with EG/ON switch signal into VCA", "manualRef": "Monarch p.47" },
    { "id": "MON_VCF_CUTOFF_IN", "panelLabel": "VCF CUTOFF", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with CUTOFF knob + VCF MOD; 1 vv/oct, ±5 sweeps 20 Hz–20 kHz at center knob", "manualRef": "Monarch p.48" },
    { "id": "MON_VCF_RES_IN", "panelLabel": "VCF RES", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with RESONANCE knob; ±5 = min-to-max at center", "manualRef": "Monarch p.48" },
    { "id": "MON_VCO_1VOCT_IN", "panelLabel": "VCO 1V/OCT", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Exponential FM; sums with FREQ knob, KB CV, VCO mod; ±5 = 8 Hz–8 kHz", "manualRef": "Monarch p.48" },
    { "id": "MON_VCO_LIN_FM_IN", "panelLabel": "VCO LIN FM", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Linear FM, audio-rate capable", "manualRef": "Monarch p.49" },
    { "id": "MON_VCO_MOD_IN", "panelLabel": "VCO MOD", "direction": "in", "signal": "cv", "normalledTo": "INTERNAL:MON_EG", "feedsInternal": "Replaces EG at the EG position of VCO MOD SOURCE switch; VCO MOD AMOUNT is the attenuator", "manualRef": "Monarch p.49" },
    { "id": "MON_LFO_RATE_IN", "panelLabel": "LFO RATE", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with RATE knob; center knob ±5 ≈ 0.18–190 Hz; abs max ≈ 600 Hz", "manualRef": "Monarch p.49" },
    { "id": "MON_MIX1_IN", "panelLabel": "MIX 1", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:MON_ZERO", "feedsInternal": "CCW side of VC MIX crossfader", "manualRef": "Monarch p.50" },
    { "id": "MON_MIX2_IN", "panelLabel": "MIX 2", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:MON_PLUS5", "feedsInternal": "CW side of VC MIX crossfader", "manualRef": "Monarch p.50" },
    { "id": "MON_VC_MIX_CTRL_IN", "panelLabel": "VC MIX CTRL", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with VC MIX knob; ±5 = full MIX1-MIX2 crossfade at center", "manualRef": "Monarch p.50" },
    { "id": "MON_MULT_IN", "panelLabel": "MULT", "direction": "in", "signal": "cv", "normalledTo": null, "feedsInternal": "Buffered splitter input feeding MULT 1 and MULT 2", "manualRef": "Monarch p.51", "notes": "accepts any signal type" },
    { "id": "MON_GATE_IN", "panelLabel": "GATE", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": "INTERNAL:MON_KB_GATE", "feedsInternal": "Triggers EG", "manualRef": "Monarch p.53", "notes": "10 V tolerant, ~3.2 V minimum on hardware; emulator threshold +2.5 vv (D8)" },
    { "id": "MON_TEMPO_IN", "panelLabel": "TEMPO", "direction": "in", "signal": "clock", "normalledTo": null, "feedsInternal": "External clock source for sequencer", "manualRef": "Monarch p.54" },
    { "id": "MON_RUN_STOP_IN", "panelLabel": "RUN/STOP", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": null, "feedsInternal": "+5 = run, 0 = stop; edges also step the pattern (clock not synced that way)", "manualRef": "Monarch p.56" },
    { "id": "MON_RESET_IN", "panelLabel": "RESET", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": null, "feedsInternal": "Rising = back to step 1; held = repeat step 1", "manualRef": "Monarch p.56" },
    { "id": "MON_HOLD_IN", "panelLabel": "HOLD", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": null, "feedsInternal": "Held = repeat current step at tempo", "manualRef": "Monarch p.56" },
    { "id": "MON_VCA_OUT", "panelLabel": "VCA", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Monarch p.47", "notes": "voice out, post-VOLUME" },
    { "id": "MON_NOISE_OUT", "panelLabel": "NOISE", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Monarch p.48", "notes": "white noise; also normalled to MIX CW side" },
    { "id": "MON_VCF_OUT", "panelLabel": "VCF", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Monarch p.48" },
    { "id": "MON_VCO_SAW_OUT", "panelLabel": "VCO SAW", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Monarch p.49", "notes": "pre-mix" },
    { "id": "MON_VCO_PULSE_OUT", "panelLabel": "VCO PULSE", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Monarch p.49", "notes": "follows PULSE WIDTH, pre-mix" },
    { "id": "MON_LFO_TRI_OUT", "panelLabel": "LFO TRI", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Monarch p.50" },
    { "id": "MON_LFO_SQ_OUT", "panelLabel": "LFO SQ", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Monarch p.50" },
    { "id": "MON_VC_MIX_OUT", "panelLabel": "VC MIX", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Monarch p.51", "notes": "crossfade of MIX1/MIX2; unpatched = variable 0..+5 fixed-voltage source via knob" },
    { "id": "MON_MULT1_OUT", "panelLabel": "MULT 1", "direction": "out", "signal": "cv", "manualRef": "Monarch p.51", "notes": "buffered copy of MULT in; any signal type" },
    { "id": "MON_MULT2_OUT", "panelLabel": "MULT 2", "direction": "out", "signal": "cv", "manualRef": "Monarch p.51", "notes": "buffered copy of MULT in; any signal type" },
    { "id": "MON_ASSIGN_OUT", "panelLabel": "ASSIGN", "direction": "out", "signal": "cv", "rangeVv": [0, 5], "manualRef": "Monarch p.52", "notes": "16 selectable sources; v1 implements only mode 2 (seq clock, one +5 pulse per step)" },
    { "id": "MON_EG_OUT", "panelLabel": "EG", "direction": "out", "signal": "cv", "rangeVv": [0, 7.5], "manualRef": "Monarch p.53" },
    { "id": "MON_KB_OUT", "panelLabel": "KB", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Monarch p.53", "notes": "note CV (keyboard/seq/MIDI), glide applied" },
    { "id": "MON_GATE_OUT", "panelLabel": "GATE", "direction": "out", "signal": "gate", "rangeVv": [0, 5], "manualRef": "Monarch p.53", "notes": "per-note gate" }
  ],
  "sequencer": {
    "type": "monarch",
    "maxSteps": 32,
    "defaultEndStep": 16,
    "tempoBpm": { "min": 20, "max": 300, "default": 120 },
    "swingPct": { "min": 0, "max": 100, "default": 50 },
    "stepDefaults": { "noteVv": -1, "gateLength": 0.5, "accent": false, "rest": false, "glide": false, "ratchet": 1 },
    "clockDivision": "1 step = 16th note fixed in v1 (24 division values deferred)",
    "deferred": ["64 pattern memories", "playback order", "KB live-play/record modes", "MIDI"],
    "manualRef": "Monarch pp.18-21, 36-44, 54"
  }
}
