{
  "id": "cascade",
  "displayName": "Cascade",
  "internalSources": ["CAS_VCO1_SUB1_SAW", "CAS_VCO2_SUB1_SAW", "CAS_VCO1_IN_SIGNAL"],
  "controls": [
    { "id": "CAS_VCO1_FREQ", "panelLabel": "VCO 1 FREQ", "type": "knob", "min": 261.63, "max": 4186, "default": 261.63, "taper": "exp", "unit": "Hz", "manualRef": "Cascade p.20", "notes": "full CCW = middle C 262 Hz, full CW = 4186 Hz; quantize snaps when engaged" },
    { "id": "CAS_VCO1_SUB1_FREQ", "panelLabel": "VCO 1 SUB 1 FREQ", "type": "knob", "min": 1, "max": 16, "default": 2, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.20", "notes": "integer divider; CW = /1 (unison) … CCW = /16" },
    { "id": "CAS_VCO1_SUB2_FREQ", "panelLabel": "VCO 1 SUB 2 FREQ", "type": "knob", "min": 1, "max": 16, "default": 3, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.21" },
    { "id": "CAS_VCO1_WAVE", "panelLabel": "VCO 1 WAVE", "type": "switch", "positions": ["SQUARE", "MIXED", "SAW"], "default": "SAW", "manualRef": "Cascade p.21", "notes": "MIXED = VCO square + subs saw, SUB 1 saw normalled into VCO PWM" },
    { "id": "CAS_VCO2_FREQ", "panelLabel": "VCO 2 FREQ", "type": "knob", "min": 261.63, "max": 4186, "default": 261.63, "taper": "exp", "unit": "Hz", "manualRef": "Cascade p.22" },
    { "id": "CAS_VCO2_SUB1_FREQ", "panelLabel": "VCO 2 SUB 1 FREQ", "type": "knob", "min": 1, "max": 16, "default": 2, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.22" },
    { "id": "CAS_VCO2_SUB2_FREQ", "panelLabel": "VCO 2 SUB 2 FREQ", "type": "knob", "min": 1, "max": 16, "default": 3, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.22" },
    { "id": "CAS_VCO2_WAVE", "panelLabel": "VCO 2 WAVE", "type": "switch", "positions": ["SQUARE", "MIXED", "SAW"], "default": "SAW", "manualRef": "Cascade p.22" },
    { "id": "CAS_QUANTIZE", "panelLabel": "QUANTIZE", "type": "button", "positions": ["OFF", "ET12", "ET8", "JI12", "JI8"], "default": "OFF", "manualRef": "Cascade p.23", "notes": "cycles; shared by both oscillators; long-press jack-decouple deferred to v1.1 (D3)" },
    { "id": "CAS_SEQ_OCT", "panelLabel": "SEQ OCT", "type": "button", "positions": ["OCT1", "OCT2", "OCT5"], "default": "OCT1", "manualRef": "Cascade p.23", "notes": "step knob range ±1/±2/±5 octaves, shared by both sequencers" },
    { "id": "CAS_VCO1_LEVEL", "panelLabel": "VCO 1 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.8, "taper": "lin", "manualRef": "Cascade p.24", "notes": "hot mixer = warm distortion (drive into filter)" },
    { "id": "CAS_VCO1_SUB1_LEVEL", "panelLabel": "VCO 1 SUB 1 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.6, "taper": "lin", "manualRef": "Cascade p.24", "notes": "non-zero by default: stacked subharmonics are this voice's signature low end (keep in sync with cascade.ts)" },
    { "id": "CAS_VCO1_SUB2_LEVEL", "panelLabel": "VCO 1 SUB 2 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.4, "taper": "lin", "manualRef": "Cascade p.24" },
    { "id": "CAS_VCO2_LEVEL", "panelLabel": "VCO 2 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.8, "taper": "lin", "manualRef": "Cascade p.24", "notes": "audible by default: SEQ 2 drives VCO 2, and both RGs/seq assigns default ON" },
    { "id": "CAS_VCO2_SUB1_LEVEL", "panelLabel": "VCO 2 SUB 1 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.6, "taper": "lin", "manualRef": "Cascade p.24", "notes": "non-zero by default: stacked subharmonics are this voice's signature low end (keep in sync with cascade.ts)" },
    { "id": "CAS_VCO2_SUB2_LEVEL", "panelLabel": "VCO 2 SUB 2 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.4, "taper": "lin", "manualRef": "Cascade p.24" },
    { "id": "CAS_CUTOFF", "panelLabel": "CUTOFF", "type": "knob", "min": 20, "max": 20000, "default": 2000, "taper": "exp", "unit": "Hz", "manualRef": "Cascade p.25" },
    { "id": "CAS_RESONANCE", "panelLabel": "RESONANCE", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.25", "notes": "self-oscillation at max resonance + low cutoff" },
    { "id": "CAS_VCF_EG_AMOUNT", "panelLabel": "VCF EG AMT", "type": "knob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26", "notes": "bipolar (D2)" },
    { "id": "CAS_VCF_ATTACK", "panelLabel": "VCF ATTACK", "type": "knob", "min": 0.001, "max": 10, "default": 0.005, "taper": "exp", "unit": "s", "manualRef": "Cascade p.26" },
    { "id": "CAS_VCF_DECAY", "panelLabel": "VCF DECAY", "type": "knob", "min": 0.005, "max": 10, "default": 0.3, "taper": "exp", "unit": "s", "manualRef": "Cascade p.26" },
    { "id": "CAS_VCA_ATTACK", "panelLabel": "VCA ATTACK", "type": "knob", "min": 0.001, "max": 10, "default": 0.005, "taper": "exp", "unit": "s", "manualRef": "Cascade p.27" },
    { "id": "CAS_VCA_DECAY", "panelLabel": "VCA DECAY", "type": "knob", "min": 0.005, "max": 10, "default": 0.5, "taper": "exp", "unit": "s", "manualRef": "Cascade p.27" },
    { "id": "CAS_VOLUME", "panelLabel": "VOLUME", "type": "knob", "min": 0, "max": 1, "default": 0.7, "taper": "lin", "manualRef": "Cascade p.19" },
    { "id": "CAS_TEMPO", "panelLabel": "TEMPO", "type": "knob", "min": 0.333, "max": 50, "default": 2, "taper": "exp", "unit": "Hz", "manualRef": "Cascade p.28", "notes": "0.333–50 Hz = 20–3000 BPM @ 1 PPQ" },
    { "id": "CAS_RHYTHM_1", "panelLabel": "RHYTHM 1", "type": "knob", "min": 1, "max": 16, "default": 1, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.30", "notes": "divider; CW = /1 … CCW = /16" },
    { "id": "CAS_RHYTHM_2", "panelLabel": "RHYTHM 2", "type": "knob", "min": 1, "max": 16, "default": 2, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM_3", "panelLabel": "RHYTHM 3", "type": "knob", "min": 1, "max": 16, "default": 3, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM_4", "panelLabel": "RHYTHM 4", "type": "knob", "min": 1, "max": 16, "default": 4, "taper": "stepped", "steps": 16, "unit": "div", "manualRef": "Cascade p.30" },
    { "id": "CAS_SEQ1_STEP_1", "panelLabel": "SEQ 1 STEP 1", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26", "notes": "bipolar; scaled by SEQ OCT range to vv" },
    { "id": "CAS_SEQ1_STEP_2", "panelLabel": "SEQ 1 STEP 2", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ1_STEP_3", "panelLabel": "SEQ 1 STEP 3", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ1_STEP_4", "panelLabel": "SEQ 1 STEP 4", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ2_STEP_1", "panelLabel": "SEQ 2 STEP 1", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ2_STEP_2", "panelLabel": "SEQ 2 STEP 2", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ2_STEP_3", "panelLabel": "SEQ 2 STEP 3", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ2_STEP_4", "panelLabel": "SEQ 2 STEP 4", "type": "stepKnob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Cascade p.26" },
    { "id": "CAS_SEQ1_ASSIGN_OSC", "panelLabel": "SEQ 1 → OSC", "type": "button", "positions": ["OFF", "ON"], "default": "ON", "manualRef": "Cascade p.27", "notes": "assign buttons toggle independently; multiple may be active" },
    { "id": "CAS_SEQ1_ASSIGN_SUB1", "panelLabel": "SEQ 1 → SUB 1", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.27" },
    { "id": "CAS_SEQ1_ASSIGN_SUB2", "panelLabel": "SEQ 1 → SUB 2", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.27" },
    { "id": "CAS_SEQ2_ASSIGN_OSC", "panelLabel": "SEQ 2 → OSC", "type": "button", "positions": ["OFF", "ON"], "default": "ON", "manualRef": "Cascade p.27" },
    { "id": "CAS_SEQ2_ASSIGN_SUB1", "panelLabel": "SEQ 2 → SUB 1", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.27" },
    { "id": "CAS_SEQ2_ASSIGN_SUB2", "panelLabel": "SEQ 2 → SUB 2", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.27" },
    { "id": "CAS_RHYTHM1_SEQ1", "panelLabel": "RHYTHM 1 → SEQ 1", "type": "button", "positions": ["OFF", "ON"], "default": "ON", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM1_SEQ2", "panelLabel": "RHYTHM 1 → SEQ 2", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM2_SEQ1", "panelLabel": "RHYTHM 2 → SEQ 1", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM2_SEQ2", "panelLabel": "RHYTHM 2 → SEQ 2", "type": "button", "positions": ["OFF", "ON"], "default": "ON", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM3_SEQ1", "panelLabel": "RHYTHM 3 → SEQ 1", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM3_SEQ2", "panelLabel": "RHYTHM 3 → SEQ 2", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM4_SEQ1", "panelLabel": "RHYTHM 4 → SEQ 1", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_RHYTHM4_SEQ2", "panelLabel": "RHYTHM 4 → SEQ 2", "type": "button", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Cascade p.30" },
    { "id": "CAS_PLAY", "panelLabel": "PLAY", "type": "button", "manualRef": "Cascade p.28", "notes": "gates sequencers, rhythm generators, CLOCK out" },
    { "id": "CAS_TRIGGER_BTN", "panelLabel": "TRIGGER", "type": "button", "manualRef": "Cascade p.28", "notes": "EG ON: restart EGs; EG OFF: acts as held-open gate; EG HELD: no effect" },
    { "id": "CAS_RESET", "panelLabel": "RESET", "type": "button", "manualRef": "Cascade p.29", "notes": "hold = stay at step 1 while EGs keep triggering; NEXT advances during hold" },
    { "id": "CAS_NEXT", "panelLabel": "NEXT", "type": "button", "manualRef": "Cascade p.29", "notes": "advance without EG retrigger" },
    { "id": "CAS_EG", "panelLabel": "EG", "type": "button", "positions": ["OFF", "ON", "HELD"], "default": "ON", "manualRef": "Cascade p.29", "notes": "HELD = long-press, blinking; EGs forced to max until exited" },
    { "id": "CAS_FINE_TUNE", "panelLabel": "FINE TUNE", "type": "knob", "min": -50, "max": 50, "default": 0, "taper": "lin", "unit": "cents", "manualRef": "Cascade p.41", "notes": "Global ±50¢ fine tune of BOTH oscillators (and their subs). A Setup-mode parameter — on the hardware it is set by holding OSC 1 + OSC 2 and turning TEMPO, NOT a front-panel knob; so it has no cascadeLayout position (engine + state + preset settable, like MON_ASSIGN_SOURCE). Stored at power-up on the real unit." }
  ],
  "jacks": [
    { "id": "CAS_VCO1_IN", "panelLabel": "VCO 1", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "1 vv/oct; sums with FREQ knob + Seq-1 steps; also normalled onward into VCO 2 in", "manualRef": "Cascade p.31" },
    { "id": "CAS_VCO1_SUB_IN", "panelLabel": "VCO 1 SUB", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Drives both VCO 1 sub divisions (1–16); center sub knobs for bipolar use", "manualRef": "Cascade p.31" },
    { "id": "CAS_VCO1_PWM_IN", "panelLabel": "VCO 1 PWM", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:CAS_VCO1_SUB1_SAW", "feedsInternal": "PWM 1–99% duty; overrides the sub-saw PWM normal (active when wave switch = MIXED)", "manualRef": "Cascade p.32" },
    { "id": "CAS_VCA_IN", "panelLabel": "VCA", "direction": "in", "signal": "cv", "rangeVv": [0, 8], "normalledTo": null, "feedsInternal": "Sums with VCA EG", "manualRef": "Cascade p.33" },
    { "id": "CAS_VCO2_IN", "panelLabel": "VCO 2", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:CAS_VCO1_IN_SIGNAL", "feedsInternal": "Patching breaks the VCO1→VCO2 pass-along normal", "manualRef": "Cascade p.33" },
    { "id": "CAS_VCO2_SUB_IN", "panelLabel": "VCO 2 SUB", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Drives both VCO 2 sub divisions", "manualRef": "Cascade p.33" },
    { "id": "CAS_VCO2_PWM_IN", "panelLabel": "VCO 2 PWM", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:CAS_VCO2_SUB1_SAW", "feedsInternal": "As VCO 1 PWM", "manualRef": "Cascade p.33" },
    { "id": "CAS_CUTOFF_IN", "panelLabel": "CUTOFF", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "±5 octaves around CUTOFF knob (centered)", "manualRef": "Cascade p.34" },
    { "id": "CAS_PLAY_IN", "panelLabel": "PLAY", "direction": "in", "signal": "gate", "rangeVv": [0, 10], "normalledTo": null, "feedsInternal": "Rising = play, falling = stop; panel button overrides", "manualRef": "Cascade p.34" },
    { "id": "CAS_RESET_IN", "panelLabel": "RESET", "direction": "in", "signal": "gate", "rangeVv": [0, 10], "normalledTo": null, "feedsInternal": "Rising = reset seqs to step 1 + RG phases; sustained high = hold at step 1 (EGs keep triggering; NEXT still advances)", "manualRef": "Cascade p.35" },
    { "id": "CAS_TRIGGER_IN", "panelLabel": "TRIGGER", "direction": "in", "signal": "gate", "rangeVv": [0, 10], "normalledTo": null, "feedsInternal": "Rising fires both EGs (never mid-Attack)", "manualRef": "Cascade p.35" },
    { "id": "CAS_RHYTHM_1_IN", "panelLabel": "RHYTHM 1", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "CV over RG 1 divider integer (1–16); center knob for best range", "manualRef": "Cascade pp.35-36" },
    { "id": "CAS_RHYTHM_2_IN", "panelLabel": "RHYTHM 2", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "CV over RG 2 divider integer", "manualRef": "Cascade pp.35-36" },
    { "id": "CAS_RHYTHM_3_IN", "panelLabel": "RHYTHM 3", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "CV over RG 3 divider integer", "manualRef": "Cascade pp.35-36" },
    { "id": "CAS_RHYTHM_4_IN", "panelLabel": "RHYTHM 4", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "CV over RG 4 divider integer", "manualRef": "Cascade pp.35-36" },
    { "id": "CAS_MIDI_IN", "panelLabel": "MIDI IN", "direction": "in", "signal": "midi", "normalledTo": null, "feedsInternal": "Type-A 3.5 mm; MIDI clock overrides analog & internal; 4 PPQN when present", "manualRef": "Cascade p.37", "notes": "v1: jack exists, MIDI deferred" },
    { "id": "CAS_CLOCK_IN", "panelLabel": "CLOCK", "direction": "in", "signal": "clock", "rangeVv": [0, 10], "normalledTo": null, "feedsInternal": "Rising edges replace the internal clock", "manualRef": "Cascade p.37" },
    { "id": "CAS_VCA_OUT", "panelLabel": "VCA", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.32", "notes": "10 Vpp" },
    { "id": "CAS_VCO1_OUT", "panelLabel": "VCO 1", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.32" },
    { "id": "CAS_VCO1_SUB1_OUT", "panelLabel": "VCO 1 SUB 1", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.32" },
    { "id": "CAS_VCO1_SUB2_OUT", "panelLabel": "VCO 1 SUB 2", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.32" },
    { "id": "CAS_VCO2_OUT", "panelLabel": "VCO 2", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.33" },
    { "id": "CAS_VCO2_SUB1_OUT", "panelLabel": "VCO 2 SUB 1", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.33" },
    { "id": "CAS_VCO2_SUB2_OUT", "panelLabel": "VCO 2 SUB 2", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Cascade p.33" },
    { "id": "CAS_VCA_EG_OUT", "panelLabel": "VCA EG", "direction": "out", "signal": "cv", "rangeVv": [0, 8], "manualRef": "Cascade p.34" },
    { "id": "CAS_VCF_EG_OUT", "panelLabel": "VCF EG", "direction": "out", "signal": "cv", "rangeVv": [0, 8], "manualRef": "Cascade p.34" },
    { "id": "CAS_SEQ1_OUT", "panelLabel": "SEQ 1", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Cascade p.36", "notes": "respects quantize & seq-oct" },
    { "id": "CAS_SEQ1_CLK_OUT", "panelLabel": "SEQ 1 CLK", "direction": "out", "signal": "clock", "rangeVv": [0, 5], "manualRef": "Cascade p.36" },
    { "id": "CAS_SEQ2_OUT", "panelLabel": "SEQ 2", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Cascade p.36" },
    { "id": "CAS_SEQ2_CLK_OUT", "panelLabel": "SEQ 2 CLK", "direction": "out", "signal": "clock", "rangeVv": [0, 5], "manualRef": "Cascade p.36" },
    { "id": "CAS_CLOCK_OUT", "panelLabel": "CLOCK", "direction": "out", "signal": "clock", "rangeVv": [0, 10], "manualRef": "Cascade p.37", "notes": "only while PLAY is lit" },
    { "id": "CAS_TRIGGER_OUT", "panelLabel": "TRIGGER", "direction": "out", "signal": "gate", "rangeVv": [0, 5], "manualRef": "Cascade p.37", "notes": "~1 ms pulse, fires whenever the EGs trigger" }
  ],
  "sequencer": {
    "type": "cascade",
    "sequencers": 2,
    "stepsPerSequencer": 4,
    "rhythmGenerators": 4,
    "tempoHz": { "min": 0.333, "max": 50, "default": 2 },
    "behavior": "Four rhythm generators divide one master tick counter by 1–16; a sequencer advances (OR-combined, one advance/one trigger per tick) when any assigned RG fires; phase-locked forever by construction. RESET held = hold at step 1. NEXT = advance without EG retrigger.",
    "manualRef": "Cascade pp.26-30, 35-37"
  }
}
