{
  "id": "anvil",
  "displayName": "Anvil",
  "internalSources": ["ANV_SEQ_CLOCK", "ANV_SEQ_VELOCITY_ROW", "ANV_NOISE"],
  "controls": [
    { "id": "ANV_VCO1_FREQUENCY", "panelLabel": "VCO 1 FREQUENCY", "type": "knob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.13", "notes": "±5 vv = the documented 10-octave / ±5 V FREQUENCY range; matches the step-PITCH knobs' own ±5" },
    { "id": "ANV_VCO2_FREQUENCY", "panelLabel": "VCO 2 FREQUENCY", "type": "knob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.13" },
    { "id": "ANV_VCO1_WAVE", "panelLabel": "VCO 1 WAVE", "type": "switch", "positions": ["TRI", "SQ"], "default": "SQ", "manualRef": "Anvil p.14" },
    { "id": "ANV_VCO2_WAVE", "panelLabel": "VCO 2 WAVE", "type": "switch", "positions": ["TRI", "SQ"], "default": "SQ", "manualRef": "Anvil p.14" },
    { "id": "ANV_HARD_SYNC", "panelLabel": "HARD SYNC", "type": "switch", "positions": ["OFF", "ON"], "default": "OFF", "manualRef": "Anvil p.15", "notes": "VCO 2 phase-locked to VCO 1" },
    { "id": "ANV_FM_AMOUNT", "panelLabel": "1→2 FM AMOUNT", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.15", "notes": "linear FM depth, VCO1 → VCO2" },
    { "id": "ANV_SEQ_PITCH_MOD", "panelLabel": "SEQ PITCH MOD", "type": "switch", "positions": ["VCO1_2", "OFF", "VCO2"], "default": "VCO1_2", "manualRef": "Anvil p.16" },
    { "id": "ANV_VCO_DECAY", "panelLabel": "VCO DECAY", "type": "knob", "min": 0.01, "max": 10, "default": 0.1, "taper": "exp", "unit": "s", "manualRef": "Anvil p.16", "notes": "shared decay-only EG for both VCO EG amounts; attack fixed 1 ms" },
    { "id": "ANV_VCO1_EG_AMOUNT", "panelLabel": "VCO 1 EG AMOUNT", "type": "knob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.16", "notes": "bipolar, center = none" },
    { "id": "ANV_VCO2_EG_AMOUNT", "panelLabel": "VCO 2 EG AMOUNT", "type": "knob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.16" },
    { "id": "ANV_VCO1_LEVEL", "panelLabel": "VCO 1 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.8, "taper": "lin", "manualRef": "Anvil p.17", "notes": "hot mixer = aggressive clip (drive into filter)" },
    { "id": "ANV_NOISE_EXT_LEVEL", "panelLabel": "NOISE / EXT LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.17", "notes": "attenuator for noise or EXT AUDIO when patched (pattern-2 normal)" },
    { "id": "ANV_VCO2_LEVEL", "panelLabel": "VCO 2 LEVEL", "type": "knob", "min": 0, "max": 1, "default": 0.8, "taper": "lin", "manualRef": "Anvil p.17" },
    { "id": "ANV_CUTOFF", "panelLabel": "CUTOFF", "type": "knob", "min": 20, "max": 20000, "default": 1000, "taper": "exp", "unit": "Hz", "manualRef": "Anvil p.18" },
    { "id": "ANV_RESONANCE", "panelLabel": "RESONANCE", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.18", "notes": "self-oscillates only at maximum, from ~1 kHz cutoff up; shares Monarch resonance curve" },
    { "id": "ANV_VCF_MODE", "panelLabel": "VCF MODE", "type": "switch", "positions": ["LP", "HP"], "default": "LP", "manualRef": "Anvil p.18" },
    { "id": "ANV_VCF_DECAY", "panelLabel": "VCF DECAY", "type": "knob", "min": 0.01, "max": 10, "default": 0.1, "taper": "exp", "unit": "s", "manualRef": "Anvil p.19" },
    { "id": "ANV_VCF_EG_AMOUNT", "panelLabel": "VCF EG AMOUNT", "type": "knob", "min": -1, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.19", "notes": "bipolar" },
    { "id": "ANV_NOISE_VCF_MOD", "panelLabel": "NOISE / VCF MOD", "type": "knob", "min": 0, "max": 1, "default": 0, "taper": "lin", "manualRef": "Anvil p.19", "notes": "attenuator for noise (or VCF MOD jack) into cutoff; the only direct cutoff-CV path" },
    { "id": "ANV_VCA_EG_ATTACK", "panelLabel": "VCA EG", "type": "switch", "positions": ["FAST", "SLOW"], "default": "FAST", "manualRef": "Anvil p.20", "notes": "FAST = 1 ms attack, SLOW = 100 ms" },
    { "id": "ANV_VCA_DECAY", "panelLabel": "VCA DECAY", "type": "knob", "min": 0.01, "max": 10, "default": 0.3, "taper": "exp", "unit": "s", "manualRef": "Anvil p.20" },
    { "id": "ANV_VOLUME", "panelLabel": "VOLUME", "type": "knob", "min": 0, "max": 1, "default": 0.7, "taper": "lin", "manualRef": "Anvil p.20" },
    { "id": "ANV_TEMPO", "panelLabel": "TEMPO", "type": "knob", "min": 0.7, "max": 700, "default": 8, "taper": "exp", "unit": "Hz", "manualRef": "Anvil p.21", "notes": "step rate; ≈10–10,000 BPM at 16ths" },
    { "id": "ANV_SEQ_PITCH_1", "panelLabel": "PITCH 1", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_2", "panelLabel": "PITCH 2", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_3", "panelLabel": "PITCH 3", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_4", "panelLabel": "PITCH 4", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_5", "panelLabel": "PITCH 5", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_6", "panelLabel": "PITCH 6", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_7", "panelLabel": "PITCH 7", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_PITCH_8", "panelLabel": "PITCH 8", "type": "stepKnob", "min": -5, "max": 5, "default": 0, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.21" },
    { "id": "ANV_SEQ_VELOCITY_1", "panelLabel": "VELOCITY 1", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_2", "panelLabel": "VELOCITY 2", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_3", "panelLabel": "VELOCITY 3", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_4", "panelLabel": "VELOCITY 4", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_5", "panelLabel": "VELOCITY 5", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_6", "panelLabel": "VELOCITY 6", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_7", "panelLabel": "VELOCITY 7", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_SEQ_VELOCITY_8", "panelLabel": "VELOCITY 8", "type": "stepKnob", "min": 0, "max": 5, "default": 4, "taper": "lin", "unit": "vv", "manualRef": "Anvil p.22" },
    { "id": "ANV_RUN_STOP", "panelLabel": "RUN/STOP", "type": "button", "manualRef": "Anvil p.23" },
    { "id": "ANV_ADVANCE", "panelLabel": "ADVANCE", "type": "button", "manualRef": "Anvil p.23", "notes": "stopped: move one step without triggering" },
    { "id": "ANV_TRIGGER", "panelLabel": "TRIGGER", "type": "button", "manualRef": "Anvil p.23", "notes": "stopped: fire current step without advancing" }
  ],
  "jacks": [
    { "id": "ANV_TRIGGER_IN", "panelLabel": "TRIGGER", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": "INTERNAL:ANV_SEQ_CLOCK", "feedsInternal": "Fires all 3 EGs at current step's velocity, no advance", "manualRef": "Anvil p.24", "notes": "10 V tolerant" },
    { "id": "ANV_VCA_CV_IN", "panelLabel": "VCA CV", "direction": "in", "signal": "cv", "rangeVv": [0, 8], "normalledTo": null, "feedsInternal": "Sums with VCA EG signal (can clip — authentic)", "manualRef": "Anvil p.24" },
    { "id": "ANV_VELOCITY_IN", "panelLabel": "VELOCITY", "direction": "in", "signal": "cv", "rangeVv": [0, 5], "normalledTo": "INTERNAL:ANV_SEQ_VELOCITY_ROW", "feedsInternal": "Sets max amplitude of all 3 EGs", "manualRef": "Anvil p.25" },
    { "id": "ANV_VCA_DECAY_IN", "panelLabel": "VCA DECAY", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with knob (center knob = widest CV range)", "manualRef": "Anvil p.25" },
    { "id": "ANV_EXT_AUDIO_IN", "panelLabel": "EXT AUDIO", "direction": "in", "signal": "audio", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:ANV_NOISE", "feedsInternal": "Replaces noise; NOISE/EXT LEVEL is its attenuator", "manualRef": "Anvil p.25", "notes": "10 Vpp nominal" },
    { "id": "ANV_VCF_DECAY_IN", "panelLabel": "VCF DECAY", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with knob", "manualRef": "Anvil p.26" },
    { "id": "ANV_NOISE_LEVEL_IN", "panelLabel": "NOISE LEVEL", "direction": "in", "signal": "cv", "rangeVv": [0, 8], "normalledTo": null, "feedsInternal": "Adds to NOISE/EXT LEVEL knob (level VCA can clip)", "manualRef": "Anvil p.26" },
    { "id": "ANV_VCO_DECAY_IN", "panelLabel": "VCO DECAY", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "Sums with knob", "manualRef": "Anvil p.26" },
    { "id": "ANV_VCF_MOD_IN", "panelLabel": "VCF MOD", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": "INTERNAL:ANV_NOISE", "feedsInternal": "Replaces noise as cutoff mod source; NOISE/VCF MOD knob is the attenuator; the only direct cutoff-CV path", "manualRef": "Anvil p.27" },
    { "id": "ANV_VCO1_CV_IN", "panelLabel": "VCO 1 CV", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "1 vv/oct; sums with FREQ knob, EG amount, seq pitch (per switch)", "manualRef": "Anvil p.27" },
    { "id": "ANV_FM_AMT_IN", "panelLabel": "1→2 FM AMT", "direction": "in", "signal": "cv", "rangeVv": [0, 8], "normalledTo": null, "feedsInternal": "Sums with FM AMOUNT knob (linear FM depth VCO1→VCO2)", "manualRef": "Anvil p.28" },
    { "id": "ANV_VCO2_CV_IN", "panelLabel": "VCO 2 CV", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "1 vv/oct", "manualRef": "Anvil p.28" },
    { "id": "ANV_TEMPO_IN", "panelLabel": "TEMPO", "direction": "in", "signal": "cv", "rangeVv": [-5, 5], "normalledTo": null, "feedsInternal": "1 vv/oct on the clock VCO, up to audio rate", "manualRef": "Anvil p.28" },
    { "id": "ANV_RUN_STOP_IN", "panelLabel": "RUN/STOP", "direction": "in", "signal": "gate", "rangeVv": [0, 5], "normalledTo": null, "feedsInternal": "+5 run / 0 stop; edges can also step (unsynced)", "manualRef": "Anvil p.29", "notes": "10 V tolerant" },
    { "id": "ANV_ADV_CLOCK_IN", "panelLabel": "ADV / CLOCK", "direction": "in", "signal": "clock", "rangeVv": [0, 5], "normalledTo": null, "feedsInternal": "Rising edge advances one step; TEMPO knob ignored while used", "manualRef": "Anvil p.29", "notes": "10 V tolerant; how Monarch/Cascade clock the Anvil (Phase 6)" },
    { "id": "ANV_VCA_OUT", "panelLabel": "VCA", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Anvil p.25", "notes": "post-VOLUME" },
    { "id": "ANV_VCA_EG_OUT", "panelLabel": "VCA EG", "direction": "out", "signal": "cv", "rangeVv": [0, 8], "manualRef": "Anvil p.25" },
    { "id": "ANV_VCF_EG_OUT", "panelLabel": "VCF EG", "direction": "out", "signal": "cv", "rangeVv": [0, 8], "manualRef": "Anvil p.26" },
    { "id": "ANV_VCO_EG_OUT", "panelLabel": "VCO EG", "direction": "out", "signal": "cv", "rangeVv": [0, 8], "manualRef": "Anvil p.27" },
    { "id": "ANV_VCO1_OUT", "panelLabel": "VCO 1", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Anvil p.27" },
    { "id": "ANV_VCO2_OUT", "panelLabel": "VCO 2", "direction": "out", "signal": "audio", "rangeVv": [-5, 5], "manualRef": "Anvil p.28" },
    { "id": "ANV_TRIGGER_OUT", "panelLabel": "TRIGGER", "direction": "out", "signal": "gate", "rangeVv": [0, 5], "manualRef": "Anvil p.28", "notes": "~1 ms pulse, fires with every sequenced note" },
    { "id": "ANV_VELOCITY_OUT", "panelLabel": "VELOCITY", "direction": "out", "signal": "cv", "rangeVv": [0, 5], "manualRef": "Anvil p.29", "notes": "current step" },
    { "id": "ANV_PITCH_OUT", "panelLabel": "PITCH", "direction": "out", "signal": "cv", "rangeVv": [-5, 5], "manualRef": "Anvil p.29", "notes": "current step" }
  ],
  "sequencer": {
    "type": "anvil",
    "steps": 8,
    "tempoHz": { "min": 0.7, "max": 700, "default": 8 },
    "stepDefaults": { "pitchVv": 0, "velocityVv": 4 },
    "behavior": "Every step fires a 1 ms trigger into all three EGs at that step's velocity; no rests, no gates. Stopped: ADVANCE steps without trigger, TRIGGER fires without advance. ADV/CLOCK patched = internal clock ignored.",
    "manualRef": "Anvil pp.21-23, 29"
  }
}
